# --- SUPABASE CONFIGURATION ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# --- OPENCODE ZEN CONFIGURATION ---
OPENCODE_API_KEY=your-opencode-zen-api-key
VOXKAGE_CLAUDE_MODEL=deepseek-v4-flash-free

# --- AUTHENTICATION & JWT ---
JWT_SECRET_KEY=generate-a-long-random-secret-key-for-jwt-signing
VOXKAGE_MASTER_KEY=your-secure-master-passphrase-to-unlock-registration

# --- SMTP / EMAIL FOR OTP SENDING ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-specific-email-password

# --- GROQ API KEY ---
GROQ_API_KEY=your-groq-api-key
