{
  "expo": {
    "name": "VoxKage",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.shinayush.voxkage"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#000000"
        }
      ],
      "expo-sharing",
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "backgroundColor": "#00000000"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow VoxKage to access your microphone to record voice instructions, Sir."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc4b280c-18fc-447d-ab6d-d78b0ff8f5e2"
      }
    }
  }
}
